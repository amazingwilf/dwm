## Keybindings config for Archcraft's BSPWM

##---------- Keybindings for bspwm ----------##

# Terminal (alacritty)
super + Return
	alacritty

super + space 
	rofi -show drun

super + w
	firefox

super + e
	thunar
# Launch Apps
super + shift + {e,w}
	{thunar,firefox}

super + shift + p
	colorpicker

ctrl + shift + l
    betterlockscreen --lock

XF86MonBrightness{Up,Down}
	brightness{ --inc, --dec}
	
XF86Audio{RaiseVolume,LowerVolume}
	volume{ --inc, --dec}

XF86Audio{Mute,MicMute}
	volume{ --toggle, --toggle-mic}

super + Escape
	pkill -USR1 -x sxhkd

